-- Unified org resolution for RLS (works for both API key and JWT auth)
-- ═══════════════════════════════════════════════════════

-- get_current_org_id(): reads app.organization_id session var set by Axum middleware
CREATE OR REPLACE FUNCTION public.get_current_org_id()
RETURNS uuid AS $$
BEGIN
  RETURN nullif(current_setting('app.organization_id', true), '')::uuid;
END;
$$ LANGUAGE plpgsql STABLE;

-- resolve_user_org(): looks up org from basejump for JWT auth
-- SECURITY DEFINER to bypass basejump RLS when called by non-superuser
-- resolve_user_org: prefer team accounts over personal, 'member' role over 'owner'
-- Personal accounts are excluded in production to enforce multi-tenant isolation.
-- Set ALLOW_PERSONAL_ORG=true in dev/test to fall back to personal account.
CREATE OR REPLACE FUNCTION public.resolve_user_org(p_user_id uuid)
RETURNS uuid AS $$
  SELECT au.account_id
  FROM basejump.account_user au
  JOIN basejump.accounts a ON a.id = au.account_id
  WHERE au.user_id = p_user_id
    AND (NOT a.personal_account OR current_setting('app.allow_personal_org', true) = 'true')
  ORDER BY
    CASE WHEN a.personal_account THEN 1 ELSE 0 END,
    CASE WHEN au.account_role = 'member' THEN 0 ELSE 1 END,
    a.created_at ASC
  LIMIT 1;
$$ LANGUAGE sql STABLE SECURITY DEFINER;

-- Grant to all roles
GRANT EXECUTE ON FUNCTION public.get_current_org_id TO authenticated, api_key, anon;
GRANT EXECUTE ON FUNCTION public.resolve_user_org TO authenticated, api_key, anon;

