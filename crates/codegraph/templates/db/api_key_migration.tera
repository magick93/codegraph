-- Step 5: Public interface functions

-- Function: Create API Key
CREATE OR REPLACE FUNCTION public.create_api_key(
    p_organization_id UUID,
    p_name TEXT,
    p_scopes JSONB,
    p_expires_at TIMESTAMPTZ DEFAULT NULL
)
    RETURNS JSONB AS
$$
DECLARE
    v_key           TEXT;
    v_key_prefix    TEXT;
    v_key_hash      TEXT;
    v_id            UUID;
    v_created_at    TIMESTAMPTZ;
BEGIN
    v_key := 'sk_' || encode(gen_random_bytes(32), 'base64');
    v_key := replace(replace(replace(v_key, '/', ''), '+', ''), '=', '');
    v_key_prefix := substring(v_key, 1, 7);
    v_key_hash := crypt(v_key, gen_salt('bf', 12));

    INSERT INTO api_keys_private.api_keys (organization_id, name, key_prefix, key_hash, scopes, expires_at, created_by)
    VALUES (p_organization_id, p_name, v_key_prefix, v_key_hash, p_scopes, p_expires_at, '00000000-0000-0000-0000-000000000000'::UUID)
    RETURNING id, created_at INTO v_id, v_created_at;

    RETURN jsonb_build_object(
            'id', v_id,
            'name', p_name,
            'key', v_key,
            'key_prefix', v_key_prefix,
            'organization_id', p_organization_id,
            'scopes', p_scopes,
            'expires_at', p_expires_at,
            'created_at', v_created_at
           );
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

-- Function: Verify API Key
CREATE OR REPLACE FUNCTION public.verify_api_key(p_api_key TEXT)
    RETURNS JSONB AS
$$
DECLARE
    v_key_prefix TEXT;
    v_key_record RECORD;
BEGIN
    v_key_prefix := substring(p_api_key, 1, 7);

    FOR v_key_record IN
        SELECT id, key_hash, organization_id, is_active, expires_at
        FROM api_keys_private.api_keys
        WHERE key_prefix = v_key_prefix AND is_active = TRUE
    LOOP
        IF crypt(p_api_key, v_key_record.key_hash) = v_key_record.key_hash THEN
            IF v_key_record.expires_at IS NOT NULL AND v_key_record.expires_at < now() THEN
                RETURN jsonb_build_object('valid', FALSE, 'error', 'API key has expired');
            END IF;
            RETURN jsonb_build_object('valid', TRUE, 'api_key_id', v_key_record.id, 'organization_id', v_key_record.organization_id);
        END IF;
    END LOOP;

    RETURN jsonb_build_object('valid', FALSE, 'error', 'Invalid API key');
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

-- Function: Log API Key Usage
CREATE OR REPLACE FUNCTION public.log_api_key_usage(
  p_api_key_id UUID, p_endpoint TEXT, p_method TEXT,
  p_status_code INTEGER, p_ip_address TEXT, p_user_agent TEXT
) RETURNS JSONB AS $$
DECLARE
  v_current_time TIMESTAMPTZ := now();
  v_log_id UUID;
BEGIN
  UPDATE api_keys_private.api_keys SET last_used_at = v_current_time WHERE id = p_api_key_id;

  INSERT INTO api_keys_private.api_key_logs (api_key_id, endpoint, method, status_code, ip_address, user_agent, timestamp)
  VALUES (p_api_key_id, p_endpoint, p_method, p_status_code, p_ip_address, p_user_agent, v_current_time)
  RETURNING id INTO v_log_id;

  RETURN jsonb_build_object('success', TRUE, 'log_id', v_log_id, 'timestamp', v_current_time);
EXCEPTION WHEN OTHERS THEN
  RETURN jsonb_build_object('success', FALSE, 'error', SQLERRM);
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

-- Function: Get Verified API Key Info (reads from session variable)
CREATE OR REPLACE FUNCTION public.get_verified_api_key_info()
 RETURNS jsonb LANGUAGE plpgsql STABLE SECURITY DEFINER
AS $function$
DECLARE
    v_api_key TEXT;
    v_result JSONB;
BEGIN
    v_api_key := current_setting('app.current_api_key', true);
    IF v_api_key IS NULL OR v_api_key = '' THEN
        RETURN jsonb_build_object('valid', false, 'error', 'No API key in session');
    END IF;
    v_result := public.verify_api_key(v_api_key);
    RETURN v_result;
END;
$function$;

-- Function: Get API Key Org ID (reads from session variable, returns org UUID)
CREATE OR REPLACE FUNCTION public.get_api_key_org_id()
 RETURNS uuid LANGUAGE plpgsql STABLE SECURITY DEFINER
AS $function$
DECLARE
    v_info JSONB;
BEGIN
    v_info = public.get_verified_api_key_info();
    IF (v_info->>'valid')::boolean = true THEN
        RETURN (v_info->>'organization_id')::uuid;
    ELSE
        RETURN NULL;
    END IF;
END;
$function$;

-- Function: Get Current API Key ID (B3 fix — was missing)
CREATE OR REPLACE FUNCTION public.get_current_api_key_id()
    RETURNS UUID AS
$$
DECLARE
    v_info JSONB;
BEGIN
    v_info := public.get_verified_api_key_info();
    IF (v_info->>'valid')::boolean = true THEN
        RETURN (v_info->>'api_key_id')::uuid;
    ELSE
        RETURN NULL;
    END IF;
END;
$$ LANGUAGE plpgsql STABLE SECURITY DEFINER;

-- Function: Check API Key Scope
CREATE OR REPLACE FUNCTION public.check_api_key_scope(p_entity_type text, p_entity_id text, p_action text)
 RETURNS boolean LANGUAGE plpgsql STABLE SECURITY DEFINER
AS $function$
DECLARE
    v_scopes JSONB;
    v_api_key_id UUID;
BEGIN
    v_api_key_id := public.get_current_api_key_id();
    IF v_api_key_id IS NULL THEN RETURN FALSE; END IF;

    SELECT scopes INTO v_scopes
    FROM api_keys_private.api_keys
    WHERE id = v_api_key_id AND is_active = TRUE AND (expires_at IS NULL OR expires_at > now());

    IF v_scopes IS NULL THEN RETURN FALSE; END IF;

    -- Global wildcard
    IF v_scopes @> '[{"entity_type": "*", "entity_id": "*", "action": "*"}]' THEN RETURN TRUE; END IF;
    -- Entity type wildcard
    IF v_scopes @> jsonb_build_array(jsonb_build_object('entity_type', p_entity_type, 'entity_id', '*', 'action', '*')) THEN RETURN TRUE; END IF;
    -- Action wildcard on entity type
    IF v_scopes @> jsonb_build_array(jsonb_build_object('entity_type', p_entity_type, 'entity_id', '*', 'action', p_action)) THEN RETURN TRUE; END IF;
    -- Specific entity + action
    IF v_scopes @> jsonb_build_array(jsonb_build_object('entity_type', p_entity_type, 'entity_id', p_entity_id, 'action', p_action)) THEN RETURN TRUE; END IF;
    -- Specific entity + wildcard action
    IF v_scopes @> jsonb_build_array(jsonb_build_object('entity_type', p_entity_type, 'entity_id', p_entity_id, 'action', '*')) THEN RETURN TRUE; END IF;

    RETURN FALSE;
END;
$function$;

