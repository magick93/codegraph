/// List all available integrations in the catalog.
#[utoipa::path(
    get,
    path = "/api/integrations/catalog",
    tag = "Integrations",
    responses(
        (status = 200, description = "OK"),
    )
)]
pub async fn list_catalog(
    State(state): State<AppState>,
) -> Result<Json<serde_json::Value>, AppError> {
    let rows = state.db
        .query_all(Statement::from_string(
            DatabaseBackend::Postgres,
            "SELECT id, name, vendor, version, description, extension_point_id, tier, categories, markets, enabled
             FROM platform_integrations.catalog WHERE enabled = TRUE ORDER BY name".to_string(),
        ))
        .await
        .map_err(|e| AppError::internal(format!("Failed to list catalog: {e}")))?;

    let items: Vec<serde_json::Value> = rows.iter().map(|r| {
        serde_json::json!({
            "id": r.try_get_by_index::<String>(0).unwrap_or_default(),
            "name": r.try_get_by_index::<String>(1).unwrap_or_default(),
            "vendor": r.try_get_by_index::<String>(2).unwrap_or_default(),
            "version": r.try_get_by_index::<String>(3).unwrap_or_default(),
            "description": r.try_get_by_index::<String>(4).unwrap_or_default(),
            "extension_point_id": r.try_get_by_index::<String>(5).unwrap_or_default(),
            "tier": r.try_get_by_index::<String>(6).unwrap_or_default(),
        })
    }).collect();

    Ok(Json(serde_json::json!({ "data": items })))
}

