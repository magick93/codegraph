/// Update settings for an installation (partial JSONB merge).
pub async fn update_installation_settings(
    State(state): State<AppState>,
    axum::extract::Extension(auth): axum::extract::Extension<AuthInfo>,
    Path(installation_id): Path<Uuid>,
    Json(body): Json<serde_json::Value>,
) -> Result<Json<serde_json::Value>, AppError> {
    // Verify installation belongs to tenant
    let _installation = state.db
        .query_one(Statement::from_sql_and_values(
            DatabaseBackend::Postgres,
            "SELECT id FROM platform_integrations.installations WHERE id = $1 AND platform_organization_id = $2",
            [installation_id.into(), auth.organization_id.into()],
        ))
        .await
        .map_err(|e| AppError::internal(format!("Installation lookup failed: {e}")))?
        .ok_or_else(|| AppError::not_found("Installation not found"))?;

    // JSONB merge: existing settings || new settings
    let _ = state.db
        .execute(Statement::from_sql_and_values(
            DatabaseBackend::Postgres,
            "UPDATE platform_integrations.installation_settings
             SET settings = settings || $1, updated_at = NOW()
             WHERE installation_id = $2 AND platform_organization_id = $3",
            [body.clone().into(), installation_id.into(), auth.organization_id.into()],
        ))
        .await
        .map_err(|e| AppError::internal(format!("Settings update failed: {e}")))?;

    Ok(Json(serde_json::json!({ "data": { "id": installation_id.to_string(), "settings": body } })))
}

