/// Install an integration for the current tenant.
#[derive(serde::Deserialize)]
pub struct InstallRequest {
    pub catalog_id: String,
    pub settings: Option<serde_json::Value>,
}

#[utoipa::path(
    post,
    path = "/api/integrations/installations",
    tag = "Integrations",
    request_body = InstallRequest,
    responses(
        (status = 201, description = "Created"),
        (status = 404, description = "Not found"),
    )
)]
pub async fn install_integration(
    State(state): State<AppState>,
    axum::extract::Extension(auth): axum::extract::Extension<AuthInfo>,
    Json(body): Json<InstallRequest>,
) -> Result<(StatusCode, Json<serde_json::Value>), AppError> {
    let catalog_row = state.db
        .query_one(Statement::from_sql_and_values(
            DatabaseBackend::Postgres,
            "SELECT extension_point_id FROM platform_integrations.catalog WHERE id = $1 AND enabled = TRUE",
            [body.catalog_id.clone().into()],
        ))
        .await
        .map_err(|e| AppError::internal(format!("Catalog lookup failed: {e}")))?
        .ok_or_else(|| AppError::not_found("Integration not found in catalog"))?;

    let extension_point_id: String = catalog_row.try_get_by_index(0)
        .map_err(|e| AppError::internal(format!("Parse error: {e}")))?;

    let row = state.db
        .query_one(Statement::from_sql_and_values(
            DatabaseBackend::Postgres,
            "INSERT INTO platform_integrations.installations (platform_organization_id, catalog_id, extension_point_id, status, installed_by)
             VALUES ($1, $2, $3, 'active', $4)
             RETURNING id",
            [
                auth.organization_id.into(),
                body.catalog_id.clone().into(),
                extension_point_id.into(),
                auth.user_id.into(),
            ],
        ))
        .await
        .map_err(|e| AppError::internal(format!("Install failed: {e}")))?
        .ok_or_else(|| AppError::internal("Install returned no ID"))?;

    let installation_id: Uuid = row.try_get_by_index(0)
        .map_err(|e| AppError::internal(format!("Parse error: {e}")))?;

    let settings = body.settings.unwrap_or(serde_json::json!({}));
    let _ = state.db
        .execute(Statement::from_sql_and_values(
            DatabaseBackend::Postgres,
            "INSERT INTO platform_integrations.installation_settings (installation_id, platform_organization_id, settings)
             VALUES ($1, $2, $3)",
            [
                installation_id.into(),
                auth.organization_id.into(),
                settings.into(),
            ],
        ))
        .await;

    Ok((StatusCode::CREATED, Json(serde_json::json!({
        "data": { "id": installation_id.to_string(), "status": "active" }
    }))))
}

/// Uninstall an integration.
#[utoipa::path(
    delete,
    path = "/api/integrations/installations/{id}",
    tag = "Integrations",
    params(("id" = Uuid, Path, description = "Installation ID")),
    responses(
        (status = 204, description = "No content"),
        (status = 404, description = "Not found"),
    )
)]
pub async fn uninstall_integration(
    State(state): State<AppState>,
    axum::extract::Extension(auth): axum::extract::Extension<AuthInfo>,
    Path(installation_id): Path<Uuid>,
) -> Result<StatusCode, AppError> {
    let affected = state.db
        .execute(Statement::from_sql_and_values(
            DatabaseBackend::Postgres,
            "DELETE FROM platform_integrations.installations WHERE id = $1 AND platform_organization_id = $2",
            [installation_id.into(), auth.organization_id.into()],
        ))
        .await
        .map_err(|e| AppError::internal(format!("Uninstall failed: {e}")))?;

    if affected.rows_affected() == 0 {
        return Err(AppError::not_found("Installation not found"));
    }

    Ok(StatusCode::NO_CONTENT)
}

