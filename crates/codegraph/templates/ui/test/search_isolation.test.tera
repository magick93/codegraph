import { test, expect } from '../../e2e/fixtures/personas';
import { createEntityAsAcme } from '../../e2e/helpers';

{% if parent %}
{% if parent.grandparent %}
const GRANDPARENT_API_PATH = '/{{ parent.grandparent.domain }}/{{ parent.grandparent.path_segment }}';
let PARENT_API_PATH: string;
{% else %}
const PARENT_API_PATH = '/{{ parent.domain }}/{{ parent.path_segment }}';
{% endif %}
let BASE_PATH: string;
{% if parent.grandparent %}
let UI_PATH: string;
{% endif %}
{% else %}
const BASE_PATH = '/{{ domain }}/{{ path_segment }}';
{% endif %}

function isolationTestData(): Record<string, unknown> {
  return {
{%- for field in required_create_fields %}
{%- if field.name == fts_search_field %}
    '{{ field.name }}': 'AcmeSearchSecret2025',
{%- elif field.input_type == "number" %}
    '{{ field.name }}': 77,
{%- elif field.input_type == "checkbox" %}
    '{{ field.name }}': true,
{%- elif field.input_type == "date" %}
    '{{ field.name }}': '2025-03-10',
{%- elif field.input_type == "datetime-local" %}
    '{{ field.name }}': '2025-03-10T09:00:00Z',
{%- elif field.is_codelist and field.codelist_values | length > 0 and field.is_array %}
    '{{ field.name }}': [{ code: '{{ field.codelist_values | first }}' }],
{%- elif field.is_codelist and field.codelist_values | length > 0 %}
    '{{ field.name }}': '{{ field.codelist_values | first }}',
{%- elif field.is_range %}
    '{{ field.name }}': '[2025-03-01T00:00:00Z,2025-12-31T23:59:59Z]',
{%- elif field.is_entity_ref %}
    // Entity ref field — omit if no dependency exists (FK constraint)
{%- elif field.structured_sub_fields | length > 0 and field.is_array %}
    '{{ field.name }}': [{ value: 'ACME Isolation {{ field.label }}' }],
{%- elif field.structured_sub_fields | length > 0 %}
    '{{ field.name }}': { value: 'ACME Isolation {{ field.label }}' },
{%- elif field.is_array %}
    '{{ field.name }}': ['ACME Isolation {{ field.label }}'],
{%- elif field.nested_type_name %}
    // '{{ field.name }}': ValueObject — omit, serde default
{%- elif field.pg_type is containing("GEOMETRY") %}
    // geometry field omitted — plain WKT strings are not accepted by the API without ST_GeomFromText
{%- elif field.input_type == "geometry" %}
    '{{ field.name }}': '{"type":"Point","coordinates":[0,0]}',
{%- else %}
    '{{ field.name }}': 'ACME Isolation {{ field.label }}',
{%- endif %}
{%- endfor %}
{%- if fts_search_field %}
{%- set fts_covered = false %}
{%- for field in required_create_fields %}
{%- if field.name == fts_search_field %}
{%- set_global fts_covered = true %}
{%- endif %}
{%- endfor %}
{%- if not fts_covered %}
    '{{ fts_search_field }}': 'AcmeSearchSecret2025',
{%- endif %}
{%- endif %}
{%- set display_field_set = false %}
{%- for field in create_fields %}
{#- Heuristic: pick the first optional plain-text field (not FTS field, not a ref/codelist/array/range,
    not a numeric/bool/date/geometry input) as an extra visible column to verify isolation.
    If no field matches this heuristic, `display_field_set` stays false and the value is simply
    omitted — the search term is already set via `fts_search_field` above, so the test will still
    find and assert on AcmeSearchSecret2025 there.  The control test (`ownerPage` can find own data)
    relies solely on the FTS column being visible, so missing a display field only means one fewer
    assertion column, not a false pass. #}
{%- if not display_field_set and field.name != fts_search_field and not field.is_required and not field.is_entity_ref and not field.is_codelist and not field.is_array and not field.is_range and field.input_type != "number" and field.input_type != "checkbox" and field.input_type != "date" and field.input_type != "datetime-local" and field.input_type != "geometry" and not (field.pg_type is containing("GEOMETRY")) and not field.nested_type_name %}
    '{{ field.name }}': 'AcmeSearchSecret2025',
{%- set_global display_field_set = true %}
{%- endif %}
{%- endfor %}
  };
}

test.describe.serial('{{ entity_name }} Search RLS Isolation', () => {
  let acmeEntityId: string;
  const data = isolationTestData();

  test.beforeAll(async ({ orgContext }) => {
{% if parent %}
{% if parent.grandparent %}
    const gpEntity = await createEntityAsAcme(orgContext, GRANDPARENT_API_PATH, { {{ grandparent_test_data_json }} });
    const gpId = gpEntity['id'] as string;
    PARENT_API_PATH = `${GRANDPARENT_API_PATH}/${gpId}/{{ parent.path_segment }}`;
{% endif %}
    const parentEntity = await createEntityAsAcme(orgContext, PARENT_API_PATH, { {{ parent_test_data_json }} });
    const parentId = parentEntity['id'] as string;
    BASE_PATH = `${PARENT_API_PATH}/${parentId}/{{ path_segment }}`;
{% if parent.grandparent %}
    // UI routes include grandparent — full depth-2 path in SvelteKit route
    UI_PATH = `/{{ parent.grandparent.domain }}/{{ parent.grandparent.path_segment }}/${gpId}/{{ parent.path_segment }}/${parentId}/{{ path_segment }}`;
{% endif %}
{% endif %}
    const entity = await createEntityAsAcme(orgContext, BASE_PATH, data);
    acmeEntityId = entity.id as string;
  });

  test('HighFive owner cannot find ACME {{ entity_name }} via search', async ({ highfiveOwnerPage }) => {
{% if parent and parent.grandparent %}
    await highfiveOwnerPage.goto(`${UI_PATH}?q=AcmeSearchSecret2025`);
{% else %}
    await highfiveOwnerPage.goto(`${BASE_PATH}?q=AcmeSearchSecret2025`);
{% endif %}
    // HighFive should see no results — ACME data must not leak through search
    const tableVisible = await highfiveOwnerPage.locator('[data-testid="{{ module_name }}-table"]').isVisible();
    if (tableVisible) {
      await expect(highfiveOwnerPage.locator('[data-testid="{{ module_name }}-table"]')).not.toContainText('AcmeSearchSecret2025');
    } else {
      // Either no-results message or empty state — both acceptable
      const noResults = highfiveOwnerPage.locator('[data-testid="{{ module_name }}-no-results"]');
      const emptyState = highfiveOwnerPage.locator('[data-testid="{{ module_name }}-empty"]');
      const hasNoResults = await noResults.isVisible().catch(() => false);
      const hasEmpty = await emptyState.isVisible().catch(() => false);
      expect(hasNoResults || hasEmpty).toBe(true);
    }
  });

  test('ACME owner CAN find own {{ entity_name }} via search (control)', async ({ ownerPage }) => {
{% if parent and parent.grandparent %}
    await ownerPage.goto(`${UI_PATH}?q=AcmeSearchSecret2025`);
{% else %}
    await ownerPage.goto(`${BASE_PATH}?q=AcmeSearchSecret2025`);
{% endif %}
    await expect(ownerPage.locator('[data-testid="{{ module_name }}-table"]')).toContainText('AcmeSearchSecret2025');
  });

  test.afterAll(async ({ orgContext }) => {
    try {
      const baseUrl = process.env.PUBLIC_API_URL ?? 'http://localhost:3000';
      await fetch(`${baseUrl}/api${BASE_PATH}/${acmeEntityId}`, {
        method: 'DELETE',
        headers: {
          'Authorization': `Bearer ${orgContext.acme.apiKey}`,
        },
      });
    } catch { /* best effort cleanup */ }
  });
});
