// Authentication E2E tests.

import { test, expect } from '@playwright/test';

{% raw %}
test.describe('Authentication', () => {
  test('unauthenticated request shows error', async ({ page }) => {
    // Intercept all API requests and strip the Authorization header
    await page.route('**/api/**', (route) => {
      const headers = { ...route.request().headers() };
      delete headers['authorization'];
      route.continue({ headers });
    });

    await page.goto('/');
    await expect(
      page.getByRole('alert').or(page.getByText(/error|unauthorized|forbidden/i))
    ).toBeVisible({ timeout: 10_000 });
  });

  test('invalid API key shows error', async ({ page }) => {
    // Intercept all API requests and replace the Authorization header
    await page.route('**/api/**', (route) => {
      const headers = { ...route.request().headers() };
      headers['authorization'] = 'Bearer sk_invalid';
      route.continue({ headers });
    });

    await page.goto('/');
    await expect(
      page.getByRole('alert').or(page.getByText(/error|unauthorized|forbidden/i))
    ).toBeVisible({ timeout: 10_000 });
  });

  test('authenticated request loads data', async ({ page }) => {
    // Default context uses the valid API key from the environment
    await page.goto('/');
    // Dashboard should load without errors
    await expect(page.getByRole('heading')).toBeVisible({ timeout: 10_000 });
    // Should not show an error
    await expect(page.getByRole('alert')).not.toBeVisible();
  });
});
{% endraw %}
