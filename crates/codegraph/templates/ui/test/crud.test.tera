    expect(result.success).toHaveLength(2);
    expect(result.failed).toHaveLength(0);
    expect(result.success[0]).toHaveProperty('id');
    expect(result.success[1]).toHaveProperty('id');
    // IDs should be distinct
    expect(result.success[0]['id']).not.toEqual(result.success[1]['id']);
  });

  test('bulk create items appear in list', async ({ ownerPage: page, orgContext }) => {
    const items = [testData(), testData()];
