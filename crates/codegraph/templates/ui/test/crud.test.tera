  test('delete entity', async ({ ownerPage: page, orgContext }) => {
    const entity = await createEntityAsAcme(orgContext, BASE_PATH, testData());
    const myId = entity['id'] as string;

{% if parent and parent.grandparent %}
    await page.goto(`${UI_PATH}/${myId}`);
{% else %}
    await page.goto(`${BASE_PATH}/${myId}`);
{% endif %}
    await waitForHydration(page, '[data-testid="{{ module_name }}-delete-btn"]');
    await page.locator('[data-testid="{{ module_name }}-delete-btn"]').click();

    // Confirm dialog should appear (portal-rendered, give it extra time)
    await expect(page.locator('[data-testid="confirm-dialog"]')).toBeVisible({ timeout: 20_000 });
    await page.locator('[data-testid="confirm-dialog-confirm"]').click();

    await expectToast(page, 'deleted', 'success');

    // Should redirect to list
    await expect(page).toHaveURL({% if parent and parent.grandparent %}UI_PATH{% else %}BASE_PATH{% endif %});

    // Entity should be gone from list (table may be absent if it was the only row)
    const table = page.locator('[data-testid="{{ module_name }}-table"]');
    const empty = page.locator('[data-testid="{{ module_name }}-empty"]');
    await expect(table.or(empty)).toBeVisible();
    if (await table.isVisible()) {
      await expect(table).not.toContainText(myId);
    }
  });
{% endif %}

{% if has_read %}
  test('404 for non-existent entity', async ({ ownerPage: page }) => {
{% if parent and parent.grandparent %}
    await page.goto(`${UI_PATH}/00000000-0000-0000-0000-000000000000`);
{% else %}
    await page.goto(`${BASE_PATH}/00000000-0000-0000-0000-000000000000`);
{% endif %}
    await expect(page.getByText(/not found|doesn.t exist/i)).toBeVisible();
  });
{% endif %}
});
