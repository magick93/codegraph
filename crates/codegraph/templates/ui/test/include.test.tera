    const response = await apiContext.get(`${API_PATH}/${entityId}?include={{ first_path.alias }}`);
    expect(response.ok()).toBeTruthy();
    const body = await response.json();
    expect(body.included).toBeDefined();
    const included = body.included['{{ first_path.alias }}'];
    expect(included).toBeDefined();
    {% if not first_path.is_dot_path %}
    expect(included.id).toBe(depIds['{{ first_path.target_dep_id }}']);
    {% endif %}
  });

  test('without ?include= has no included field', async ({ apiContext }) => {
    const response = await apiContext.get(`${API_PATH}/${entityId}`);
    expect(response.ok()).toBeTruthy();
    const body = await response.json();
    expect(body.included).toBeUndefined();
  });
  {% endif %}

  {% if e2e_include.has_multi_include %}
  test('?include=path1,path2 includes all related entities', async ({ apiContext }) => {
    const joined = '{% for p in e2e_include.test_paths %}{{ p.alias }}{% if not loop.last %},{% endif %}{% endfor %}';
    const response = await apiContext.get(`${API_PATH}/${entityId}?include=${joined}`);
    expect(response.ok()).toBeTruthy();
    const body = await response.json();
    expect(body.included).toBeDefined();
    {% for p in e2e_include.test_paths %}
    expect(body.included['{{ p.alias }}']).toBeDefined();
    {% endfor %}
  });
  {% endif %}

  test('unknown include path returns 400', async ({ apiContext }) => {
    const response = await apiContext.get(`${API_PATH}/${entityId}?include=_invalid_include_test_`);
    expect(response.status()).toBe(400);
  });

  test('include depth beyond 3 returns 400', async ({ apiContext }) => {
    const response = await apiContext.get(`${API_PATH}/${entityId}?include=a.b.c.d`);
    expect(response.status()).toBe(400);
  });

  // ── List endpoint tests ────────────────────────────────────────────────
  {% if e2e_include.test_list_include %}
  test('list with ?include= returns included data', async ({ apiContext }) => {
    const response = await apiContext.get(`${API_PATH}?include={% if e2e_include.test_paths | length > 0 %}{{ first_path.alias }}{% endif %}&page_size=50`);
    expect(response.ok()).toBeTruthy();
    const body = await response.json();
    expect(body.included).toBeDefined();
    expect(Array.isArray(body.data)).toBeTruthy();
    expect(body.data.length).toBeGreaterThanOrEqual(1);
  });

  test('list without ?include= has no included field', async ({ apiContext }) => {
    const response = await apiContext.get(API_PATH);
    expect(response.ok()).toBeTruthy();
    const body = await response.json();
    expect(body.included).toBeUndefined();
  });
  {% endif %}

  // ── Cleanup ────────────────────────────────────────────────────────────
  test.afterAll(async ({ orgContext }) => {
    const baseUrl = process.env.PUBLIC_API_URL ?? 'http://localhost:3000';
    // Delete in reverse creation order (main entity first, deps last)
    {% for step in e2e_include.setup_steps | reverse %}
    if (depIds['{{ step.dep_id }}']) {
      try {
        await fetch(`${baseUrl}/api{{ step.api_path }}/${depIds['{{ step.dep_id }}']}`, {
          method: 'DELETE',
          headers: { 'Authorization': `Bearer ${orgContext.acme.apiKey}` },
        });
      } catch { /* best effort */ }
    }
    {% endfor %}
