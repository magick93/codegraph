// Webhook delivery E2E tests.

import { test, expect } from '../fixtures/personas';
import { waitForHydration, startWebhookTestServer, createEntityAsAcme } from '../helpers';

test.describe('Webhook Delivery', () => {
  // Run sequentially — both tests share the same testServer and parallel
  // execution races on the shared requests array.
  test.describe.configure({ mode: 'serial' });
  let testServer: { server: any; url: string; requests: Array<any> };

  test.beforeAll(async () => {
    testServer = await startWebhookTestServer();
  });

  test.afterAll(() => {
    testServer.server.close();
  });

  test('delivers webhook on entity mutation', async ({ ownerPage, orgContext }) => {
    test.setTimeout(180000);
    await ownerPage.goto('/settings/webhooks');
    await waitForHydration(ownerPage, 'body.hydrated');

    // 1. Create webhook endpoint pointing to test server
    await ownerPage.click('text=Add Endpoint');
    await ownerPage.waitForURL('/settings/webhooks/new');
    await waitForHydration(ownerPage, '[data-testid="webhook-endpoint-submit-btn"]');
    await ownerPage.fill('#url', testServer.url);
    await ownerPage.fill('#description', 'E2E test webhook');
    await ownerPage.click('[data-testid="webhook-endpoint-submit-btn"]');
    await ownerPage.waitForURL(/\/settings\/webhooks\/[a-f0-9-]+$/, { timeout: 15000 });
    const endpointId = ownerPage.url().split('/').pop();

    // 2. Subscribe to timecard events via API
    const subResp = await fetch(
      `${process.env.PUBLIC_API_URL ?? 'http://localhost:3000'}/api/webhooks/webhook-endpoints/${endpointId}/subscriptions`,
      {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          Authorization: `Bearer ${orgContext.acme.apiKey}`,
        },
        body: JSON.stringify({
          event_domain: 'timecard',
          event_entity: null,
          event_type: null,
        }),
      },
    );
    expect(subResp.ok).toBeTruthy();

    // 3. Create a timecard entity via the API to trigger an event
    // All timecard fields are optional, so empty {} creates a valid entity.
    await createEntityAsAcme(orgContext, '/timecard/timecard', {}).catch(() => {});

    // 4. Wait for dispatch worker to drain queue backlog and deliver
    await ownerPage.waitForTimeout(30000);

    // 5. Check the test server received the webhook
    await expect.poll(async () => testServer.requests.length, {
      timeout: 60000,
      message: 'expected at least one webhook delivery',
    }).toBeGreaterThan(0);
    const webhook = testServer.requests[testServer.requests.length - 1];

    // 6. Verify webhook payload shape
    expect(webhook.method).toBe('POST');
    expect(webhook.body.event_type).toBeTruthy();
    expect(webhook.body.entity_id).toBeTruthy();
    expect(webhook.body.tenant_id).toBeTruthy();
    expect(webhook.body.correlation_id).toBeTruthy();

    // 7. Verify HMAC signature header
    const signature = webhook.headers['x-webhook-signature'];
    expect(signature).toBeTruthy();
    expect(signature).toContain('sha256=');

    // 8. Check delivery log shows delivered status
    await ownerPage.goto(`/settings/webhooks/${endpointId}`);
    await expect(ownerPage.getByText('Delivered').first()).toBeVisible();
  });

  test('retries failed delivery and deactivates endpoint', async ({ ownerPage, orgContext }) => {
    test.setTimeout(180000);
    await ownerPage.goto('/settings/webhooks');
    await waitForHydration(ownerPage, 'body.hydrated');

    // 1. Create webhook endpoint pointing to unreachable URL
    await ownerPage.click('text=Add Endpoint');
    await ownerPage.waitForURL('/settings/webhooks/new');
    await waitForHydration(ownerPage, '[data-testid="webhook-endpoint-submit-btn"]');
    await ownerPage.fill('#url', 'http://localhost:1/webhook');
    await ownerPage.click('[data-testid="webhook-endpoint-submit-btn"]');
    await ownerPage.waitForURL(/\/settings\/webhooks\/[a-f0-9-]+$/, { timeout: 15000 });
    const endpointId = ownerPage.url().split('/').pop();

    // 2. Subscribe via API
    const subResp = await fetch(
      `${process.env.PUBLIC_API_URL ?? 'http://localhost:3000'}/api/webhooks/webhook-endpoints/${endpointId}/subscriptions`,
      {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          Authorization: `Bearer ${orgContext.acme.apiKey}`,
        },
        body: JSON.stringify({
          event_domain: 'timecard',
          event_entity: null,
          event_type: null,
        }),
      },
    );
    expect(subResp.ok).toBeTruthy();

    // 3. Trigger an event
    await createEntityAsAcme(orgContext, '/timecard/timecard', {}).catch(() => {});

    // 4. Wait for dispatch worker to drain queue backlog and attempt delivery
    await ownerPage.waitForTimeout(30000);

    // 5. Check delivery log shows failure
    await ownerPage.goto(`/settings/webhooks/${endpointId}`);
    await waitForHydration(ownerPage, 'body.hydrated');
    await expect(ownerPage.getByText('Failed')).toBeVisible({ timeout: 60000 });
  });
});
