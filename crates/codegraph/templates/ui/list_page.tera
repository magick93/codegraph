			</Empty.Header>
{% endraw %}
{% if has_create %}
{% raw %}{#if $page.data.organization?.role === 'owner'}{% endraw %}
			<Empty.Content>
				<Button href={`${basePath}/new`}>+ {% raw %}{{% endraw %}m.{{ domain }}_{{ module_name }}_new(){% raw %}}{% endraw %}</Button>
			</Empty.Content>
{% raw %}{/if}{% endraw %}
{% endif %}
{% raw %}
		</Empty.Root>
	{:else if displayRows.length === 0 && searchQuery}
		<div class="py-12 text-center text-muted-foreground" data-testid="{% endraw %}{{ module_name }}{% raw %}-no-results">
			{m.common_no_results({ query: searchQuery })}
		</div>
	{:else}
		<div class="rounded-md border">
			<Table.Root data-testid="{% endraw %}{{ module_name }}{% raw %}-table">
				<Table.Header>
					<Table.Row>
						{#each columns as col}
							<Table.Head>{col.label}</Table.Head>
						{/each}
					</Table.Row>
				</Table.Header>
				<Table.Body>
					{#each displayRows as row}
						<Table.Row
							class="cursor-pointer hover:bg-muted/50"
							onclick={() => handleRowClick(row as Record<string, unknown>)}
							onkeydown={(e) => { if (e.key === 'Enter') handleRowClick(row as Record<string, unknown>); }}
							tabindex="0"
						>
							{#each columns as col}
								<Table.Cell>
									{#if isBooleanField((row as Record<string, unknown>)[col.key])}
										<Badge variant={(row as Record<string, unknown>)[col.key] ? 'default' : 'secondary'}>
											{formatValue((row as Record<string, unknown>)[col.key])}
										</Badge>
									{:else}
										{formatValue((row as Record<string, unknown>)[col.key])}
									{/if}
								</Table.Cell>
							{/each}
						</Table.Row>
					{/each}
				</Table.Body>
