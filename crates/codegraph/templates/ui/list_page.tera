	import type { {{ entity_name }}Response } from '$lib/api/types';
	import * as m from '$lib/paraglide/messages.js';

{% if parent and parent.grandparent %}
	const grandparentId = $derived($page.params.{{ parent.grandparent.param_name }});
	const parentId = $derived($page.params.{{ parent.param_name }});
	const basePath = $derived(`/{{ parent.grandparent.domain }}/{{ parent.grandparent.path_segment }}/${grandparentId}/{{ parent.path_segment }}/${parentId}/{{ path_segment }}`);
{% elif parent %}
	const parentId = $derived($page.params.{{ parent.param_name }});
	const basePath = $derived(`/{{ parent.domain }}/{{ parent.path_segment }}/${parentId}/{{ path_segment }}`);
{% else %}
	const basePath = '/{{ domain }}/{{ path_segment }}';
{% endif %}

	interface Props {
		data: {
			items: {{ entity_name }}Response[];
			page: number;
			pageSize: number;
{% if has_fts %}
			total: number | null;
			query: string | null;
{% endif %}
		};
	}

	let { data }: Props = $props();
{% if has_fts %}
	let searchQuery = $state(data.query ?? '');
{% else %}
	let searchQuery = $state('');
{% endif %}

	const columns = [
{% for field in list_fields %}
		{ key: '{{ field.name }}', label: m.{{ domain }}_{{ module_name }}_field_{{ field.name }}() },
{% endfor %}
{% if list_fields | length == 0 %}
		{ key: 'id', label: 'ID' },
{% endif %}
	];

{% if has_fts %}
	// Server-side search: data.items already filtered by API
	const displayRows = $derived(data.items);
{% else %}
	const displayRows = $derived(
		searchQuery
			? data.items.filter(item =>
				Object.values(item).some(v =>
					String(v ?? '').toLowerCase().includes(searchQuery.toLowerCase())
				)
			)
			: data.items
	);
{% endif %}

	function handleRowClick(row: Record<string, unknown>) {
		goto(`${basePath}/${row['id']}`);
	}

{% if has_fts %}
	function handlePageChange(newPage: number) {
		const params = new URLSearchParams();
		params.set('page', String(newPage));
		params.set('page_size', String(data.pageSize));
		if (searchQuery) params.set('q', searchQuery);
		goto(`${basePath}?${params.toString()}`);
	}
{% else %}
	function handlePageChange(newPage: number) {
		goto(`${basePath}?page=${newPage}&page_size=${data.pageSize}`);
	}
{% endif %}

{% if has_fts %}
	function handleSearch(query: string) {
		searchQuery = query;
		if (query) {
			goto(`${basePath}?q=${encodeURIComponent(query)}&page=0&page_size=${data.pageSize}`);
		} else {
			goto(basePath);
		}
	}
{% else %}
{% raw %}
	function handleSearch(query: string) {
		searchQuery = query;
	}
{% endraw %}
{% endif %}

{% raw %}
	function formatObject(obj: Record<string, unknown>): string {
		for (const key of ['value', 'code', 'name', 'id']) {
			if (key in obj && obj[key] != null) return String(obj[key]);
		}
		const vals = Object.values(obj).filter(v => v != null && typeof v !== 'object');
		return vals.length ? String(vals[0]) : JSON.stringify(obj);
	}

	function formatValue(value: unknown): string {
		if (value === null || value === undefined) return '\u2014';
		if (typeof value === 'boolean') return value ? m.common_yes() : m.common_no();
		if (Array.isArray(value)) return value.map(v => typeof v === 'object' && v !== null ? formatObject(v as Record<string, unknown>) : String(v)).join(', ');
		if (typeof value === 'object' && value !== null) return formatObject(value as Record<string, unknown>);
		return String(value);
	}

	function isBooleanField(value: unknown): boolean {
		return typeof value === 'boolean';
	}
{% endraw %}
</script>

<div class="space-y-4">
