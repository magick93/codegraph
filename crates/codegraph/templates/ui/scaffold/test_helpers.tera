// Generated by hr-graph. DO NOT EDIT.
// Shared Playwright test helpers.

import { expect, type Page } from '@playwright/test';

const BASE_URL = process.env.PUBLIC_API_URL ?? 'http://localhost:3000';
const API_KEY = process.env.PUBLIC_API_KEY ?? '';

function authHeaders(): Record<string, string> {
  const headers: Record<string, string> = {
    'Content-Type': 'application/json',
    'Accept': 'application/json',
  };
  if (API_KEY) {
    headers['Authorization'] = `Bearer ${API_KEY}`;
  }
  return headers;
}

/** Create an entity via the API (bypasses UI for fast setup). */
export async function createEntityViaApi(
  path: string,
  data: Record<string, unknown>
): Promise<Record<string, unknown>> {
  const res = await fetch(`${BASE_URL}/api${path}`, {
    method: 'POST',
    headers: authHeaders(),
    body: JSON.stringify(data),
  });
  if (!res.ok) {
    throw new Error(`API POST ${path} failed: ${res.status} ${await res.text()}`);
  }
  const json = await res.json();
  return json.data ?? json;
}

/** Delete an entity via the API (bypasses UI for fast teardown). */
export async function deleteEntityViaApi(path: string, id: string): Promise<void> {
  const res = await fetch(`${BASE_URL}/api${path}/${id}`, {
    method: 'DELETE',
    headers: authHeaders(),
  });
  if (!res.ok && res.status !== 404) {
    throw new Error(`API DELETE ${path}/${id} failed: ${res.status}`);
  }
}

/** Assert a toast notification appears with the expected message and type. */
export async function expectToast(
  page: Page,
  message: string,
  type: 'success' | 'error'
): Promise<void> {
  // Sonner toast: [data-sonner-toast][data-type="success"|"error"]
  const toast = page.locator(`[data-sonner-toast][data-type="${type}"]`);
  await expect(toast).toBeVisible({ timeout: 20000 });
  await expect(toast).toContainText(message);
}

/** Assert the data table contains a row with the given text. */
export async function expectTableContains(
  page: Page,
  testId: string,
  text: string
): Promise<void> {
  const table = page.locator(`[data-testid="${testId}"]`);
  await expect(table).toBeVisible();
  await expect(table).toContainText(text);
}

/** Bulk-create entities via API. Returns the 207 Multi-Status response with success/failed arrays. */
export async function bulkCreateEntitiesViaApi(
  path: string,
  items: Record<string, unknown>[],
): Promise<{ success: Record<string, unknown>[]; failed: { index: number; error: string }[] }> {
  const res = await fetch(`${BASE_URL}/api${path}`, {
    method: 'POST',
    headers: authHeaders(),
    body: JSON.stringify(items),
  });
  if (res.status === 207) {
    return await res.json();
  }
  throw new Error(`Bulk create API POST ${path} unexpected status: ${res.status} ${await res.text()}`);
}

/** Bulk-create entities via API as raw fetch — returns the raw Response for status code assertions. */
export async function bulkCreateRaw(
  path: string,
  body: unknown,
  headers?: Record<string, string>,
): Promise<Response> {
  return fetch(`${BASE_URL}/api${path}`, {
    method: 'POST',
    headers: headers ?? authHeaders(),
    body: JSON.stringify(body),
  });
}

/** Assert the data table does NOT contain a row with the given text. */
export async function expectTableNotContains(
  page: Page,
  testId: string,
  text: string
): Promise<void> {
  const table = page.locator(`[data-testid="${testId}"]`);
  await expect(table).toBeVisible();
  await expect(table).not.toContainText(text);
}

/**
 * Wait for Svelte 5 to hydrate the page and attach event handlers.
 * The app layout adds a `hydrated` class to <body> via onMount/afterNavigate,
 * which fires after all child components have mounted. Then we wait for the
 * target element to be visible, ensuring dynamically-rendered components
 * (e.g. WorkflowPanel inside {% raw %}{#if}{% endraw %}) have also mounted.
 */
export async function waitForHydration(
  page: Page,
  selector: string,
  timeout = 20_000,
): Promise<void> {
  await page.waitForSelector('body.hydrated', { timeout });
  await page.locator(selector).waitFor({ state: 'visible', timeout });
}

// --- Webhook test server ---

import * as http from 'http';

/**
 * Starts a lightweight HTTP server that captures incoming webhook requests.
 * Returns { server, url, requests } where requests is an array of captured
 * payloads. Call `server.close()` in afterAll/afterEach to clean up.
 */
export function startWebhookTestServer(): Promise<{
  server: http.Server;
  url: string;
  requests: Array<{ body: any; headers: Record<string, string>; method: string }>;
}> {
  return new Promise((resolve) => {
    const requests: Array<{ body: any; headers: Record<string, string>; method: string }> = [];
    const server = http.createServer((req, res) => {
      let body = '';
      req.on('data', (chunk) => (body += chunk));
      req.on('end', () => {
        try {
          requests.push({
            body: JSON.parse(body),
            headers: req.headers as Record<string, string>,
            method: req.method || 'UNKNOWN',
          });
        } catch {
          requests.push({
            body: body,
            headers: req.headers as Record<string, string>,
            method: req.method || 'UNKNOWN',
          });
        }
        res.writeHead(200, { 'Content-Type': 'application/json' });
        res.end(JSON.stringify({ received: true }));
      });
    });
    server.listen(0, () => {
      const addr = server.address();
      const port = typeof addr === 'object' && addr ? addr.port : 9999;
      resolve({ server, url: `http://localhost:${port}`, requests });
    });
  });
}

// --- Persona-aware helpers ---

import type { OrgContext } from './fixtures/personas';

const API_URL = process.env.PUBLIC_API_URL ?? 'http://localhost:3000';
const DATABASE_URL = process.env.DATABASE_URL ?? 'postgres://postgres:postgres@localhost:54322/postgres';

/**
 * Create an entity via API as the ACME owner (using API key).
 * Returns the created entity including its `id`.
 */
export async function createEntityAsAcme(
  orgContext: OrgContext,
  path: string,
  data: Record<string, unknown>,
): Promise<Record<string, unknown>> {
  const response = await fetch(`${API_URL}/api${path}`, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      Authorization: `Bearer ${orgContext.acme.apiKey}`,
    },
    body: JSON.stringify(data),
  });
  if (!response.ok) {
    const body = await response.text();
    throw new Error(`createEntityAsAcme failed (${response.status}): ${body}`);
  }
  const result = await response.json();
  return result.data ?? result;
}

/**
 * Delete an entity via API as the ACME owner (using API key).
 * Used for teardown in persona-aware tests.
 */
export async function deleteEntityAsAcme(
  orgContext: OrgContext,
  path: string,
  id: string,
): Promise<void> {
  const response = await fetch(`${API_URL}/api${path}/${id}`, {
    method: 'DELETE',
    headers: {
      'Content-Type': 'application/json',
      Authorization: `Bearer ${orgContext.acme.apiKey}`,
    },
  });
  if (!response.ok && response.status !== 404) {
    const body = await response.text();
    throw new Error(`deleteEntityAsAcme failed (${response.status}): ${body}`);
  }
}

/**
 * Set a worker's profile avatar URL by directly updating the database.
 * Used for org-chart profile card tests that need avatar data.
 */
export async function setWorkerAvatarUrl(
  workerId: string,
  avatarUrl: string,
  mimeType = 'image/jpeg',
): Promise<void> {
  const pg = await import('pg');
  const client = new pg.default.Client({ connectionString: DATABASE_URL });
  await client.connect();
  try {
    const result = await client.query(
      'UPDATE common.worker_person SET avatar_url = $1, avatar_mime_type = $2 WHERE worker_id = $3',
      [avatarUrl, mimeType, workerId],
    );
    if (result.rowCount === 0) {
      throw new Error(`No worker_person found for worker_id=${workerId}`);
    }
  } finally {
    await client.end();
  }
}

