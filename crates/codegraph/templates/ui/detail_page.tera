	import { page } from '$app/state';
{% endif %}
	import { Button } from '$lib/components/ui/button/index.js';
	import { Badge } from '$lib/components/ui/badge/index.js';
	import * as Card from '$lib/components/ui/card/index.js';
	import * as AlertDialog from '$lib/components/ui/alert-dialog/index.js';
{% if has_workflow %}
	import WorkflowPanel from '$lib/components/ui/WorkflowPanel.svelte';
	import { transition{{ entity_name }} } from '$lib/stores/{{ domain }}_{{ module_name }}';
{% endif %}
{% if has_delete %}
	import { delete{{ entity_name }} } from '$lib/stores/{{ domain }}_{{ module_name }}';
{% endif %}
{% if has_child_sections %}
