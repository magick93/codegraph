{% if has_delete %}
{% raw %}
<AlertDialog.Root open={deleteDialogOpen} onOpenChange={(v) => deleteDialogOpen = v}>
	<AlertDialog.Content data-testid="confirm-dialog">
		<AlertDialog.Header>
			<AlertDialog.Title>{m.common_confirm_delete_title({ entity: '{% endraw %}{{ entity_name }}{% raw %}' })}</AlertDialog.Title>
			<AlertDialog.Description>
				{m.common_confirm_delete_description()}
			</AlertDialog.Description>
		</AlertDialog.Header>
		<AlertDialog.Footer>
			<AlertDialog.Cancel>{m.common_cancel()}</AlertDialog.Cancel>
			<AlertDialog.Action
				onclick={handleDelete}
				disabled={deleting}
				data-testid="confirm-dialog-confirm"
				class="bg-destructive text-destructive-foreground hover:bg-destructive/90"
			>
				{deleting ? m.common_deleting() : m.common_delete()}
			</AlertDialog.Action>
		</AlertDialog.Footer>
	</AlertDialog.Content>
</AlertDialog.Root>
{% endraw %}
{% endif %}
