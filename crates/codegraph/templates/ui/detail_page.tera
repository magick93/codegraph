	import { apiGet, apiPost, apiDelete } from '$lib/api/client';
{% endif %}
	import { TimeAgo } from '@crewbase/entities';
	import { toast } from 'svelte-sonner';
	import * as m from '$lib/paraglide/messages.js';
	import type { {{ entity_name }}Response } from '$lib/api/types';

	function formatRange(range: unknown): string {
		if (!range || typeof range !== 'string') return '—';
		const inner = range.slice(1, -1);
		const [start, end] = inner.split(',');
		const fmt = new Intl.DateTimeFormat('en-US', { dateStyle: 'medium' });
		try {
			const startStr = start && start.trim() ? fmt.format(new Date(start.trim())) : '';
			if (!end || end.trim() === '') return `${startStr} — Ongoing`;
			return `${startStr} — ${fmt.format(new Date(end.trim()))}`;
		} catch {
			return String(range);
		}
	}

	interface Props {
		data: {
			item: {{ entity_name }}Response;
		};
	}

	let { data }: Props = $props();
	let item = $state(data.item);
{% if parent and parent.grandparent %}
	const grandparentId = $derived(page.params.{{ parent.grandparent.param_name }});
	const parentId = $derived(page.params.{{ parent.param_name }});
	const basePath = $derived(`/{{ parent.grandparent.domain }}/{{ parent.grandparent.path_segment }}/${grandparentId}/{{ parent.path_segment }}/${parentId}/{{ path_segment }}`);
{% elif parent %}
	const parentId = $derived(page.params.{{ parent.param_name }});
	const basePath = $derived(`/{{ parent.domain }}/{{ parent.path_segment }}/${parentId}/{{ path_segment }}`);
{% else %}
	const basePath = '/{{ domain }}/{{ path_segment }}';
{% endif %}
{% if has_delete %}
	let deleteDialogOpen = $state(false);
	let deleting = $state(false);
{% endif %}
{% if has_workflow %}
	let transitioning = $state(false);
{% endif %}
{% if has_child_sections %}
	let expandedSections = $state(new Set<string>());
{% for section in child_sections %}
	let {{ section.module_name }}Items = $state<any[]>([]);
{% endfor %}

	function toggleSection(name: string) {
		expandedSections = new Set(expandedSections);
		if (expandedSections.has(name)) {
			expandedSections.delete(name);
		} else {
			expandedSections.add(name);
		}
	}

	async function loadChildren() {
{% for section in child_sections %}
		try {
			const res = await apiGet<any[]>('/api/{{ section.domain }}/{{ section.path_segment }}', { parent_id: item.id });
			{{ section.module_name }}Items = res ?? [];
		} catch {
			{{ section.module_name }}Items = [];
		}
{% endfor %}
	}

	function startAddChild(domain: string, pathSegment: string) {
		goto(`/${domain}/${pathSegment}/new?parent_id=${item.id}`);
	}

	function editChild(domain: string, pathSegment: string, childId: string) {
		goto(`/${domain}/${pathSegment}/${childId}/edit`);
	}

	function manageChild(domain: string, pathSegment: string, childId: string) {
		pushChild(
			{
				label: '{{ entity_name }}',
				path: `${basePath}/${item.id}`,
				entityType: '{{ entity_name }}',
				entityId: item.id,
			},
			{
				parentId: item.id,
				parentType: '{{ entity_name }}',
				parentLabel: '{{ entity_name }}',
			}
		);
		goto(`/${domain}/${pathSegment}/${childId}`);
	}

	async function deleteChild(domain: string, pathSegment: string, childId: string) {
		try {
			await apiDelete(`/api/${domain}/${pathSegment}/${childId}`);
			toast.success(m.common_child_deleted());
			await loadChildren();
		} catch (e) {
			toast.error(m.common_delete_failed({ error: (e as Error).message }));
		}
	}

	onMount(() => {
		loadChildren();
	});
{% endif %}

{% if has_delete %}
	async function handleDelete() {
		deleting = true;
		try {
{% if parent and parent.grandparent %}
			await delete{{ entity_name }}(grandparentId, parentId, item.id);
{% elif parent %}
			await delete{{ entity_name }}(parentId, item.id);
{% else %}
			await delete{{ entity_name }}(item.id);
{% endif %}
			toast.success(m.common_entity_deleted({ entity: '{{ entity_name }}' }));
			goto(basePath);
		} catch (e) {
			toast.error(m.common_delete_failed({ error: (e as Error).message }));
		} finally {
			deleting = false;
			deleteDialogOpen = false;
		}
	}
{% endif %}

{% if has_workflow %}
	async function handleTransition(targetState: string) {
		transitioning = true;
		try {
{% if parent and parent.grandparent %}
			const ws = await transition{{ entity_name }}(grandparentId, parentId, item.id, targetState);
{% elif parent %}
			const ws = await transition{{ entity_name }}(parentId, item.id, targetState);
{% else %}
			const ws = await transition{{ entity_name }}(item.id, targetState);
{% endif %}
			item.workflow_state = {
				current_state: ws.current_state,
				is_terminal: ws.is_terminal,
				available_transitions: ws.available_transitions,
			};
			toast.success(m.common_transitioned_to({ state: targetState }));
		} catch (e) {
			toast.error(m.common_transition_failed({ error: (e as Error).message }));
		} finally {
			transitioning = false;
		}
	}
{% endif %}
</script>

<div class="space-y-6">
	<!-- Header -->
	<div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
		<div>
{% if has_child_sections %}
{% raw %}
			{#if $entityNavigation.breadcrumbs.length > 0}
				<nav class="flex items-center gap-1 text-sm text-muted-foreground" aria-label="Breadcrumb">
					<a href={basePath} class="hover:text-foreground hover:underline">&larr; {m.common_back_to_list()}</a>
					{#each $entityNavigation.breadcrumbs as crumb, i}
						<span class="mx-1">/</span>
						<button
							class="hover:text-foreground hover:underline"
							onclick={() => { popTo(i); goto(crumb.path); }}
							type="button"
						>
							{crumb.label} ({crumb.entityId.slice(0, 8)})
						</button>
					{/each}
					<span class="mx-1">/</span>
					<span class="text-foreground font-medium">{% endraw %}{{ entity_name }}{% raw %}</span>
				</nav>
			{:else}
				<a href={basePath} class="text-sm text-muted-foreground hover:text-foreground hover:underline">
					&larr; Back to list
				</a>
			{/if}
{% endraw %}
{% else %}
			<a href={basePath} class="text-sm text-muted-foreground hover:text-foreground hover:underline">
				&larr; {% raw %}{{% endraw %}m.common_back_to_list(){% raw %}}{% endraw %}
			</a>
{% endif %}
			<h2 class="mt-1 text-xl font-semibold">{% raw %}{{% endraw %}m.{{ domain }}_{{ module_name }}_title(){% raw %}}{% endraw %}</h2>
		</div>
		<div class="flex gap-2">
{% if has_update %}
{% raw %}{#if page.data.organization?.role === 'owner'}{% endraw %}
			<Button variant="outline" href={`${basePath}/${item.id}/edit`} data-testid="{{ module_name }}-edit-btn">
