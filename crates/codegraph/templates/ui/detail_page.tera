			</Button>
{% raw %}{/if}{% endraw %}
{% endif %}
{% if has_delete %}
{% raw %}
			{#if page.data.organization?.role === 'owner'}
				<Button variant="destructive" onclick={() => deleteDialogOpen = true} data-testid="{% endraw %}{{ module_name }}{% raw %}-delete-btn">
					{m.common_delete()}
				</Button>
			{/if}
{% endraw %}
{% endif %}
		</div>
	</div>

{% if has_workflow %}
{% raw %}
	{#if item.workflow_state}
		<WorkflowPanel
			state={item.workflow_state}
			onTransition={handleTransition}
			loading={transitioning}
		/>
	{/if}
{% endraw %}
{% endif %}

	<!-- Fields -->
	<Card.Root>
		<Card.Content class="p-0">
			<dl class="divide-y divide-border">
{% for field in fields %}
				<div class="grid grid-cols-1 gap-1 px-4 py-3 sm:grid-cols-3 sm:gap-4">
					<dt class="text-sm font-medium text-muted-foreground">{% raw %}{{% endraw %}m.{{ domain }}_{{ module_name }}_field_{{ field.name }}(){% raw %}}{% endraw %}</dt>
					<dd class="text-sm sm:col-span-2" data-testid="{{ module_name }}-field-{{ field.name }}">
{% if field.input_type == "checkbox" %}
						{% raw %}{#if item.{% endraw %}{{ field.name }}{% raw %} === true}
							<Badge>{m.common_yes()}</Badge>
						{:else if item.{% endraw %}{{ field.name }}{% raw %} === false}
							<Badge variant="secondary">{m.common_no()}</Badge>
						{:else}
							—
						{/if}{% endraw %}
{% elif field.input_type == "date-range" %}
						{% raw %}{#if item.{% endraw %}{{ field.name }}{% raw %}}
							{formatRange(item.{% endraw %}{{ field.name }}{% raw %})}
						{:else}
							—
						{/if}{% endraw %}
{% elif field.structured_sub_fields | length > 0 and not field.is_array %}
						{% raw %}{#if item.{% endraw %}{{ field.name }}{% raw %}}
							{@const obj = item.{% endraw %}{{ field.name }}{% raw %} as Record<string, unknown>}
							{obj.value ?? obj.code ?? obj.name ?? obj.id ?? '—'}
							{#if obj.schemeId}
								<span class="text-muted-foreground text-xs">({obj.schemeId})</span>
							{/if}
						{:else}—{/if}{% endraw %}
{% elif field.structured_sub_fields | length > 0 and field.is_array %}
						{% raw %}{#if Array.isArray(item.{% endraw %}{{ field.name }}{% raw %}) && item.{% endraw %}{{ field.name }}{% raw %}.length > 0}
							<ul class="list-disc list-inside">
								{#each (item.{% endraw %}{{ field.name }}{% raw %} as Record<string, string>[]) as id}
									<li>{id.value ?? id.code ?? id.name ?? id.id ?? '—'}{#if id.schemeId} <span class="text-muted-foreground text-xs">({id.schemeId})</span>{/if}</li>
								{/each}
							</ul>
						{:else}—{/if}{% endraw %}
{% elif field.input_type == "array" %}
						{% raw %}{#if Array.isArray(item.{% endraw %}{{ field.name }}{% raw %}) && item.{% endraw %}{{ field.name }}{% raw %}.length > 0}
							<ul class="list-disc list-inside">
								{#each item.{% endraw %}{{ field.name }}{% raw %} as val}
									<li>{val}</li>
								{/each}
							</ul>
						{:else}
							—
						{/if}{% endraw %}
{% else %}
						{% raw %}{{% endraw %}item.{{ field.name }} ?? '—'{% raw %}}{% endraw %}
{% endif %}
					</dd>
				</div>
{% endfor %}
				<div class="grid grid-cols-1 gap-1 px-4 py-3 sm:grid-cols-3 sm:gap-4">
					<dt class="text-sm font-medium text-muted-foreground">{% raw %}{m.common_created_at()}{% endraw %}</dt>
					<dd class="text-sm sm:col-span-2">{% raw %}{#if item.created_at}<TimeAgo value={item.created_at} />{:else}—{/if}{% endraw %}</dd>
